# Keycloak (requeridas para el frontend administrativo)
VITE_KEYCLOAK_URL=http://localhost:8180
VITE_KEYCLOAK_REALM=tdm
VITE_KEYCLOAK_CLIENT_ID=tdm-frontend

# Opcional. Si no se define, se usa window.location.origin (localhost o IP de la LAN).
# Todas las URLs usadas deben estar registradas en Keycloak como Valid redirect URIs y Web origins.
# VITE_KEYCLOAK_REDIRECT_URI=http://localhost:5173

# Opcional. Solo necesaria para SSO silencioso con checkLoginIframe / check-sso.
# VITE_KEYCLOAK_SILENT_CHECK_SSO_REDIRECT_URI=

# login-required | check-sso
VITE_KEYCLOAK_ON_LOAD=login-required

# API. Si no se define, el frontend usa http://<mismo-host-que-la-página>:8080/api/v1
# para que localhost y acceso desde otra máquina en la red funcionen sin cambios.
# VITE_API_URL=http://localhost:8080/api/v1
